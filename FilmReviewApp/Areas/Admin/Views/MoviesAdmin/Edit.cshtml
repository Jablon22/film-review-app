@model AdminMovieFormViewModel
@{
    ViewData["Title"] = "Edytuj film";
}

<header class="my-3">
    <h1 class="h3"><i class="fa-solid fa-pen me-2" aria-hidden="true"></i>Edytuj film</h1>
</header>

<section class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TmdbId" />

            @if (!string.IsNullOrEmpty(Model.PosterUrl))
            {
                <div class="mb-3">
                    <span class="form-label d-block">Aktualny plakat</span>
                    <img src="@Model.PosterUrl" alt="Aktualny plakat filmu @Model.Title" width="100" class="rounded" />
                </div>
            }

            <partial name="_MovieForm" model="Model" />
            <button type="submit" class="btn btn-success mt-3"><i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>Zapisz zmiany</button>
            <a asp-action="Index" class="btn btn-outline-secondary mt-3">Anuluj</a>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
