@model List<FilmReviewApp.Models.ViewModels.PendingReviewItem>
@{
    ViewData["Title"] = "Moderacja recenzji";
    var showAll = (bool)(ViewData["ShowAll"] ?? false);
}

<header class="my-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1 class="h3 mb-0"><i class="fa-solid fa-comments me-2" aria-hidden="true"></i>Moderacja recenzji</h1>
    <div class="btn-group" role="group" aria-label="Filtr recenzji">
        <a asp-action="Index" asp-route-showAll="false" class="btn btn-sm @(!showAll ? "btn-warning" : "btn-outline-warning")">Oczekujące</a>
        <a asp-action="Index" asp-route-showAll="true" class="btn btn-sm @(showAll ? "btn-warning" : "btn-outline-warning")">Wszystkie</a>
    </div>
</header>

@if (Model.Any())
{
    <div class="vstack gap-3">
        @foreach (var r in Model)
        {
            <article class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h2 class="h6 mb-1">
                                <a asp-area="" asp-controller="Movies" asp-action="Details" asp-route-id="@r.MovieId">@r.MovieTitle</a>
                                <span class="badge bg-warning text-dark ms-1"><i class="fa-solid fa-star me-1" aria-hidden="true"></i>@r.Rating/10</span>
                            </h2>
                            <p class="text-muted small mb-2">
                                <i class="fa-solid fa-user me-1" aria-hidden="true"></i>@r.UserName ·
                                @r.CreatedAt.ToString("d MMM yyyy, HH:mm")
                            </p>
                        </div>
                        <div class="d-flex gap-2">
                            <form asp-action="Approve" asp-route-id="@r.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">
                                    <i class="fa-solid fa-check me-1" aria-hidden="true"></i>Zatwierdź
                                </button>
                            </form>
                            <form asp-action="Reject" asp-route-id="@r.Id" method="post" class="confirm-delete-form"
                                  data-confirm-message="Odrzucić i usunąć tę recenzję?">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-xmark me-1" aria-hidden="true"></i>Odrzuć
                                </button>
                            </form>
                        </div>
                    </div>
                    <p class="mb-0 border-start border-3 ps-3">@r.Content</p>
                </div>
            </article>
        }
    </div>
}
else
{
    <div class="alert alert-light border">
        <i class="fa-solid fa-circle-check text-success me-1" aria-hidden="true"></i>
        @(showAll ? "Brak recenzji w systemie." : "Brak recenzji oczekujących na moderację.")
    </div>
}
