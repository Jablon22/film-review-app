@model HomeIndexViewModel
@{
    ViewData["Title"] = "Strona główna";
    var siteTitle = ViewData["SiteTitle"] as string ?? "FilmReview";
}

<section class="hero" style="@(Model.FeaturedMovie?.PosterUrl is not null ? $"background-image:url('{Model.FeaturedMovie.PosterUrl}')" : "background-color:#14161a")">
    <div class="container hero-content">
        <div class="row">
            <div class="col-lg-8">
                <p class="text-warning text-uppercase fw-bold mb-2 small">
                    <i class="fa-solid fa-clapperboard me-1" aria-hidden="true"></i>@siteTitle
                </p>
                <h1 class="display-5 fw-bold">@Model.HeroDescription</h1>
                @if (Model.FeaturedMovie is not null)
                {
                    <div class="mt-4 p-3 rounded bg-dark bg-opacity-50 d-inline-block">
                        <p class="text-uppercase small text-warning mb-1">Film dnia</p>
                        <h2 class="h4 mb-1">@Model.FeaturedMovie.Title <span class="text-secondary">(@Model.FeaturedMovie.Year)</span></h2>
                        @if (Model.FeaturedMovie.AverageRating > 0)
                        {
                            <partial name="_StarRating" model="Model.FeaturedMovie.AverageRating" />
                        }
                        <div class="mt-3">
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.FeaturedMovie.Id" class="btn btn-warning">
                                <i class="fa-solid fa-circle-info me-1" aria-hidden="true"></i>Zobacz szczegóły
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Movies" asp-action="Index" class="btn btn-warning mt-3">Przeglądaj katalog</a>
                }
            </div>
        </div>
    </div>
</section>

<section class="container my-5" aria-label="Statystyki serwisu">
    <div class="row g-3 text-center">
        <div class="col-md-4">
            <div class="card stat-card bg-primary p-3">
                <div class="stat-number">@Model.MovieCount</div>
                <div><i class="fa-solid fa-film me-1" aria-hidden="true"></i>Filmów w bazie</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card bg-success p-3">
                <div class="stat-number">@Model.ReviewCount</div>
                <div><i class="fa-solid fa-comments me-1" aria-hidden="true"></i>Recenzji</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card bg-secondary p-3">
                <div class="stat-number">@Model.UserCount</div>
                <div><i class="fa-solid fa-users me-1" aria-hidden="true"></i>Użytkowników</div>
            </div>
        </div>
    </div>
</section>

@if (Model.TopRated.Any())
{
    <section class="container my-5" aria-label="Najwyżej oceniane filmy">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h4 mb-0"><i class="fa-solid fa-trophy text-warning me-2" aria-hidden="true"></i>Najwyżej oceniane</h2>
            <a asp-controller="Movies" asp-action="Index" class="btn btn-sm btn-outline-dark">Zobacz wszystkie</a>
        </div>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-6 g-3">
            @foreach (var movie in Model.TopRated)
            {
                <div class="col">
                    <partial name="_MovieCard" model="movie" />
                </div>
            }
        </div>
    </section>
}

@if (Model.RecentlyAdded.Any())
{
    <section class="container my-5" aria-label="Ostatnio dodane filmy">
        <h2 class="h4 mb-3"><i class="fa-solid fa-clock-rotate-left text-primary me-2" aria-hidden="true"></i>Ostatnio dodane</h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-6 g-3">
            @foreach (var movie in Model.RecentlyAdded)
            {
                <div class="col">
                    <partial name="_MovieCard" model="movie" />
                </div>
            }
        </div>
    </section>
}
