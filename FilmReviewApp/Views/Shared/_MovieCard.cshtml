@model FilmReviewApp.Models.Movie
@{
    var inWatchlist = ViewData["InWatchlist"] as HashSet<int>;
    var alreadyInList = inWatchlist?.Contains(Model.Id) ?? false;
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
}
<article class="card movie-card shadow-sm">
    <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none">
        @if (!string.IsNullOrEmpty(Model.PosterUrl))
        {
            <img src="@Model.PosterUrl" class="movie-poster" alt="Plakat filmu @Model.Title" loading="lazy" />
        }
        else
        {
            <div class="poster-placeholder" aria-hidden="true"><i class="fa-solid fa-film"></i></div>
        }
    </a>
    <div class="card-body d-flex flex-column">
        <h3 class="h6 card-title mb-1">
            <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.Id" class="text-dark text-decoration-none stretched-link-none">
                @Model.Title
            </a>
        </h3>
        <p class="text-muted small mb-2">@Model.Year@(string.IsNullOrEmpty(Model.Director) ? "" : " · " + Model.Director)</p>
        <div class="mb-2">
            @if (Model.AverageRating > 0)
            {
                <partial name="_StarRating" model="Model.AverageRating" />
            }
            else
            {
                <span class="text-muted small">Brak ocen</span>
            }
        </div>
        <div class="mt-auto d-flex gap-2">
            <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-dark flex-grow-1">
                Szczegóły
            </a>
            @if (isAuth)
            {
                <form asp-controller="Watchlist" asp-action="Add" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="movieId" value="@Model.Id" />
                    <button type="submit" class="btn btn-sm @(alreadyInList ? "btn-success" : "btn-outline-warning")"
                            aria-label="@(alreadyInList ? "W watchliście" : "Dodaj do watchlisty")"
                            title="@(alreadyInList ? "W watchliście" : "Dodaj do watchlisty")" @(alreadyInList ? "disabled" : "")>
                        <i class="fa-solid @(alreadyInList ? "fa-check" : "fa-plus")" aria-hidden="true"></i>
                    </button>
                </form>
            }
        </div>
    </div>
</article>
