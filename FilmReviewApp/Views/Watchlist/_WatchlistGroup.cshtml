@model List<FilmReviewApp.Models.ViewModels.WatchlistEntry>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="fa-solid fa-clapperboard fa-2x mb-2" aria-hidden="true"></i>
        <p class="mb-0">Brak filmów w tej kategorii.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var e in Model)
        {
            var newStatus = e.Status == WatchStatus.WantToWatch ? WatchStatus.Watched : WatchStatus.WantToWatch;
            var toggleLabel = e.Status == WatchStatus.WantToWatch ? "Oznacz jako obejrzane" : "Przenieś do „Chcę obejrzeć”";
            <div class="col">
                <article class="card h-100 border-0 shadow-sm">
                    <div class="row g-0 h-100">
                        <div class="col-4">
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@e.MovieId">
                                @if (!string.IsNullOrEmpty(e.PosterUrl))
                                {
                                    <img src="@e.PosterUrl" class="img-fluid h-100 w-100" style="object-fit:cover;border-radius:.5rem 0 0 .5rem;" alt="Plakat filmu @e.MovieTitle" />
                                }
                                else
                                {
                                    <div class="poster-placeholder h-100" aria-hidden="true"><i class="fa-solid fa-film"></i></div>
                                }
                            </a>
                        </div>
                        <div class="col-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h3 class="h6 mb-1">
                                    <a asp-controller="Movies" asp-action="Details" asp-route-id="@e.MovieId" class="text-dark text-decoration-none">@e.MovieTitle</a>
                                </h3>
                                <p class="text-muted small mb-2">@e.Year</p>
                                @if (e.AverageRating > 0)
                                {
                                    <partial name="_StarRating" model="e.AverageRating" />
                                }
                                <div class="mt-auto d-flex gap-1 pt-2">
                                    <form asp-controller="Watchlist" asp-action="ChangeStatus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <input type="hidden" name="status" value="@((int)newStatus)" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary" title="@toggleLabel" aria-label="@toggleLabel">
                                            <i class="fa-solid fa-right-left" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                    <form asp-controller="Watchlist" asp-action="Remove" method="post" class="confirm-delete-form"
                                          data-confirm-message="Usunąć „@e.MovieTitle” z watchlisty?">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Usuń z watchlisty" aria-label="Usuń z watchlisty">
                                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}
