@model WatchlistViewModel
@{
    ViewData["Title"] = "Moja watchlista";
}

<section class="container my-4">
    <h1 class="h3 mb-4"><i class="fa-solid fa-list-check text-warning me-2" aria-hidden="true"></i>Moja watchlista</h1>

    <ul class="nav nav-tabs mb-3" id="watchlistTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="want-tab" data-bs-toggle="tab" data-bs-target="#want"
                    type="button" role="tab" aria-controls="want" aria-selected="true">
                <i class="fa-solid fa-bookmark me-1" aria-hidden="true"></i>Chcę obejrzeć
                <span class="badge bg-secondary">@Model.WantToWatch.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="watched-tab" data-bs-toggle="tab" data-bs-target="#watched"
                    type="button" role="tab" aria-controls="watched" aria-selected="false">
                <i class="fa-solid fa-circle-check me-1" aria-hidden="true"></i>Obejrzane
                <span class="badge bg-secondary">@Model.Watched.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="want" role="tabpanel" aria-labelledby="want-tab">
            @await Html.PartialAsync("_WatchlistGroup", Model.WantToWatch)
        </div>
        <div class="tab-pane fade" id="watched" role="tabpanel" aria-labelledby="watched-tab">
            @await Html.PartialAsync("_WatchlistGroup", Model.Watched)
        </div>
    </div>
</section>
