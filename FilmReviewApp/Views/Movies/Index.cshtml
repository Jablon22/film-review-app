@model MovieCatalogViewModel
@{
    ViewData["Title"] = "Katalog filmów";
}

<section class="container my-4">
    <header class="mb-4">
        <h1 class="h3"><i class="fa-solid fa-film text-warning me-2" aria-hidden="true"></i>Katalog filmów</h1>
        <p class="text-muted mb-0">Znaleziono @Model.TotalCount @(Model.TotalCount == 1 ? "film" : "filmów").</p>
    </header>

    <div class="row g-4">
        <aside class="col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h6 mb-3"><i class="fa-solid fa-filter me-1" aria-hidden="true"></i>Filtry</h2>

                    <div class="mb-3 position-relative">
                        <label for="catalogSearch" class="form-label small">Szybkie wyszukiwanie</label>
                        <input id="catalogSearch" type="search" class="form-control" placeholder="Wpisz tytuł..."
                               autocomplete="off" data-live-search="true" aria-label="Szybkie wyszukiwanie filmu" />
                        <ul id="catalogSearchResults" class="list-group position-absolute w-100 shadow" style="z-index:1080;"></ul>
                    </div>

                    <form asp-action="Index" method="get">
                        <div class="mb-3">
                            <label for="search" class="form-label small">Tytuł zawiera</label>
                            <input id="search" name="search" value="@Model.Search" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label for="genre" class="form-label small">Gatunek</label>
                            <select id="genre" name="genre" class="form-select">
                                <option value="">— Wszystkie —</option>
                                @foreach (var g in Model.AllGenres)
                                {
                                    if (g == Model.SelectedGenre)
                                    {
                                        <option value="@g" selected>@g</option>
                                    }
                                    else
                                    {
                                        <option value="@g">@g</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="year" class="form-label small">Rok</label>
                            <select id="year" name="year" class="form-select">
                                <option value="">— Dowolny —</option>
                                @foreach (var y in Model.AllYears)
                                {
                                    if (Model.SelectedYear == y)
                                    {
                                        <option value="@y" selected>@y</option>
                                    }
                                    else
                                    {
                                        <option value="@y">@y</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning"><i class="fa-solid fa-magnifying-glass me-1" aria-hidden="true"></i>Filtruj</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Wyczyść filtry</a>
                        </div>
                    </form>
                </div>
            </div>
        </aside>

        <div class="col-lg-9">
            @if (Model.Movies.Any())
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
                    @foreach (var movie in Model.Movies)
                    {
                        <div class="col">
                            <partial name="_MovieCard" model="movie" />
                        </div>
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Paginacja" class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-search="@Model.Search" asp-route-genre="@Model.SelectedGenre" asp-route-year="@Model.SelectedYear">
                                    Poprzednia
                                </a>
                            </li>
                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                                       asp-route-search="@Model.Search" asp-route-genre="@Model.SelectedGenre" asp-route-year="@Model.SelectedYear">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-search="@Model.Search" asp-route-genre="@Model.SelectedGenre" asp-route-year="@Model.SelectedYear">
                                    Następna
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-clapperboard fa-3x mb-3" aria-hidden="true"></i>
                    <p>Brak filmów spełniających kryteria.</p>
                </div>
            }
        </div>
    </div>
</section>
